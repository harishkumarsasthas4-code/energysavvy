{
  "name": "energy-savvy-code",
  "version": "1.0.0",
  "description": "GitHub Action for detecting energy anti-patterns in JavaScript and Python code",
  "main": "index.js",
  "bin": {
    "energy-savvy": "./src/cli.js"
  },
  "scripts": {
    "build": "ncc build index.js -o dist",
    "test": "jest --coverage",
    "lint": "eslint .",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run lint"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^5.1.1",
    "@actions/exec": "^1.1.1",
    "acorn": "^8.11.2",
    "acorn-walk": "^8.3.0",
    "diff": "^5.1.0",
    "badge-maker": "^3.3.1",
    "esprima": "^4.0.1",
    "glob": "^10.3.10",
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "table": "^6.8.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "jest": "^29.7.0",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0"
  },
  "keywords": [
    "github-action",
    "energy-efficiency",
    "green-coding",
    "sustainability",
    "code-analysis",
    "javascript",
    "python"
  ],
  "author": "Energy Savvy Code Team",
  "license": "MIT",
  "engines": {
    "node": ">=16"
  }
